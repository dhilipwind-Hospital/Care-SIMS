NODE_ENV=production
PORT=10000
APP_NAME=Ayphen HMS API
FRONTEND_URL=https://your-frontend-url.vercel.app

# Database - Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT
JWT_ACCESS_SECRET=your-strong-random-secret-64-chars
JWT_REFRESH_SECRET=another-strong-random-secret-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# MFA
MFA_ISSUER=AyphenHMS

# Encryption (PHI at rest - 32 chars)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@ayphen.io

# Platform Admin Seed
PLATFORM_ADMIN_EMAIL=admin@ayphen.io
PLATFORM_ADMIN_PASSWORD=YourStrongPassword

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=300
