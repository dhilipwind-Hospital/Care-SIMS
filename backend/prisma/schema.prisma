// ─────────────────────────────────────────
// DIET / NUTRITION
// ─────────────────────────────────────────

model DietOrder {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  locationId      String    @map("location_id")
  patientId       String    @map("patient_id")
  admissionId     String    @map("admission_id")
  wardId          String?   @map("ward_id")
  bedId           String?   @map("bed_id")
  doctorId        String    @map("doctor_id")
  dietType        String    @map("diet_type")
  caloricTarget   Int?      @map("caloric_target")
  proteinTarget   Int?      @map("protein_target")
  restrictions    String[]
  allergies       String[]
  preferences     String?
  specialInstructions String? @map("special_instructions")
  npoStatus       Boolean   @default(false) @map("npo_status")
  npoReason       String?   @map("npo_reason")
  startDate       DateTime  @default(now()) @map("start_date")
  endDate         DateTime? @map("end_date")
  status          String    @default("ACTIVE")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  meals DietMeal[]

  @@index([tenantId, admissionId])
  @@map("diet_orders")
}

model DietMeal {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  orderId         String    @map("order_id")
  mealType        String    @map("meal_type")
  mealDate        DateTime  @map("meal_date") @db.Date
  items           Json
  servedAt        DateTime? @map("served_at")
  servedById      String?   @map("served_by")
  consumedPercent Int?      @map("consumed_percent")
  refusalReason   String?   @map("refusal_reason")
  notes           String?
  status          String    @default("PLANNED")
  createdAt       DateTime  @default(now()) @map("created_at")

  order DietOrder @relation(fields: [orderId], references: [id])

  @@map("diet_meals")
}

// ─────────────────────────────────────────
// MORTUARY
// ─────────────────────────────────────────

model MortuaryRecord {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  locationId        String    @map("location_id")
  recordNumber      String    @unique @map("record_number")
  patientId         String?   @map("patient_id")
  admissionId       String?   @map("admission_id")
  deceasedName      String    @map("deceased_name")
  age               Int?
  gender            String
  dateOfDeath       DateTime  @map("date_of_death")
  timeOfDeath       String?   @map("time_of_death")
  causeOfDeath      String?   @map("cause_of_death")
  attendingDoctorId String?   @map("attending_doctor_id")
  pronouncedById    String?   @map("pronounced_by")
  deathCertificateNo String?  @map("death_certificate_no")
  unitNumber        String?   @map("unit_number")
  receivedAt        DateTime  @default(now()) @map("received_at")
  releasedAt        DateTime? @map("released_at")
  releasedTo        String?   @map("released_to")
  releasedToRelation String?  @map("released_to_relation")
  releasedToId      String?   @map("released_to_id")
  policeNotified    Boolean   @default(false) @map("police_notified")
  autopsyRequired   Boolean   @default(false) @map("autopsy_required")
  autopsyStatus     String?   @map("autopsy_status")
  embalmed          Boolean   @default(false)
  status            String    @default("IN_CUSTODY")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@map("mortuary_records")
}

model PatientAccount {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  dateOfBirth  DateTime? @map("date_of_birth")
  gender       String?
  bloodGroup   String?   @map("blood_group")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  deviceTokens Json?     @default("[]") @map("device_tokens")
  apnsToken    String?   @map("apns_token")
  fcmToken     String?   @map("fcm_token")
  deviceType   String?   @map("device_type")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("patient_accounts")
}
