generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// PLATFORM LEVEL (public schema)
// ─────────────────────────────────────────

model PlatformUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  platformRole String   @default("SUPPORT") @map("platform_role")
  mfaSecret    String?  @map("mfa_secret")
  mfaEnabled   Boolean  @default(true) @map("mfa_enabled")
  isActive     Boolean  @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdTenants    Tenant[]           @relation("CreatedBy")
  platformAuditLogs PlatformAuditLog[]

  @@map("platform_users")
}

model Tenant {
  id                 String    @id @default(uuid())
  slug               String    @unique
  legalName          String    @map("legal_name")
  tradeName          String?   @map("trade_name")
  orgType            String    @map("org_type")
  regNumber          String?   @map("reg_number")
  gstNumber          String?   @map("gst_number")
  panNumber          String?   @map("pan_number")
  nabhNumber         String?   @map("nabh_number")
  nablNumber         String?   @map("nabl_number")
  primaryEmail       String    @map("primary_email")
  primaryPhone       String    @map("primary_phone")
  website            String?
  logoUrl            String?   @map("logo_url")
  subscriptionPlan   String    @default("STARTER") @map("subscription_plan")
  subscriptionStatus String    @default("TRIAL") @map("subscription_status")
  trialEndsAt        DateTime? @map("trial_ends_at")
  billingEmail       String?   @map("billing_email")
  timezone           String    @default("Asia/Kolkata")
  currency           String    @default("INR")
  country            String    @default("IN")
  dateFormat         String    @default("DD/MM/YYYY") @map("date_format")
  allowSelfRegistration Boolean @default(false) @map("allow_self_registration")
  allowPatientPortal Boolean   @default(false) @map("allow_patient_portal")
  maxLocations       Int       @default(1) @map("max_locations")
  maxUsers           Int       @default(10) @map("max_users")
  isActive           Boolean   @default(true) @map("is_active")
  suspendedReason    String?   @map("suspended_reason")
  suspendedAt        DateTime? @map("suspended_at")
  createdById        String?   @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  createdBy     PlatformUser?        @relation("CreatedBy", fields: [createdById], references: [id])
  locations     TenantLocation[]
  features      OrganizationFeature[]
  affiliations  DoctorOrgAffiliation[]

  @@map("tenants")
}

model TenantLocation {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  locationCode        String   @map("location_code")
  name                String
  type                String   @default("BRANCH")
  addressLine1        String   @map("address_line1")
  addressLine2        String?  @map("address_line2")
  city                String
  state               String
  pinCode             String   @map("pin_code")
  country             String   @default("IN")
  phone               String?
  email               String?
  pharmacyLicenseNo   String?  @map("pharmacy_license_no")
  labLicenseNo        String?  @map("lab_license_no")
  gstin               String?
  operatingHours      Json?    @map("operating_hours")
  emergencyAvailable  Boolean  @default(false) @map("emergency_available")
  timezone            String   @default("Asia/Kolkata")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  affiliations DoctorOrgAffiliation[]

  @@unique([tenantId, locationCode])
  @@map("tenant_locations")
}

model FeatureModule {
  id               String   @id @default(uuid())
  moduleId         String   @unique @map("module_id")
  name             String
  description      String?
  category         String
  applicableTypes  String[] @map("applicable_types")
  minPlan          String   @default("STARTER") @map("min_plan")
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  orgFeatures OrganizationFeature[]

  @@map("feature_modules")
}

model OrganizationFeature {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  moduleId   String    @map("module_id")
  isEnabled  Boolean   @default(false) @map("is_enabled")
  config     Json?
  enabledById String?  @map("enabled_by")
  enabledAt  DateTime? @map("enabled_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant  Tenant        @relation(fields: [tenantId], references: [id])
  module  FeatureModule @relation(fields: [moduleId], references: [moduleId])

  @@unique([tenantId, moduleId])
  @@map("organization_features")
}

model DoctorRegistry {
  id                    String    @id @default(uuid())
  email                 String    @unique
  passwordHash          String    @map("password_hash")
  mfaSecret             String?   @map("mfa_secret")
  mfaEnabled            Boolean   @default(false) @map("mfa_enabled")
  firstName             String    @map("first_name")
  lastName              String    @map("last_name")
  phone                 String    @unique
  gender                String
  dateOfBirth           DateTime  @map("date_of_birth")
  photoUrl              String?   @map("photo_url")
  aadhaarNumber         String?   @map("aadhaar_number")
  aadhaarVerified       Boolean   @default(false) @map("aadhaar_verified")
  primaryDegree         String    @map("primary_degree")
  pgDegree              String?   @map("pg_degree")
  pgSpecialization      String?   @map("pg_specialization")
  university            String?
  yearOfPassing         Int?      @map("year_of_passing")
  experienceYears       Int?      @map("experience_years")
  specialties           String[]
  subspecialties        String[]
  languages             String[]
  certifications        Json?
  medicalCouncil        String    @map("medical_council")
  registrationNo        String    @map("registration_no")
  registrationDate      DateTime  @map("registration_date")
  registrationExpiry    DateTime? @map("registration_expiry")
  regCertificateUrl     String?   @map("reg_certificate_url")
  nmcId                 String?   @map("nmc_id")
  additionalRegistrations Json?   @map("additional_registrations")
  bio                   String?
  linkedinUrl           String?   @map("linkedin_url")
  ayphenStatus          String    @default("PENDING") @map("ayphen_status")
  verifiedById          String?   @map("verified_by")
  verifiedAt            DateTime? @map("verified_at")
  rejectionReason       String?   @map("rejection_reason")
  suspensionReason      String?   @map("suspension_reason")
  suspendedAt           DateTime? @map("suspended_at")
  lastLogin             DateTime? @map("last_login")
  deviceTokens          Json?     @default("[]") @map("device_tokens")
  apnsToken             String?   @map("apns_token")
  fcmToken              String?   @map("fcm_token")
  deviceType            String?   @map("device_type")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  affiliations DoctorOrgAffiliation[]

  @@unique([medicalCouncil, registrationNo])
  @@map("doctor_registry")
}

model DoctorOrgAffiliation {
  id                  String    @id @default(uuid())
  doctorId            String    @map("doctor_id")
  tenantId            String    @map("tenant_id")
  locationId          String?   @map("location_id")
  designation         String?
  employmentType      String    @map("employment_type")
  departmentName      String?   @map("department_name")
  availableDays       String[]  @map("available_days")
  availableSlots      Json?     @map("available_slots")
  slotDurationMinutes Int       @default(15) @map("slot_duration_minutes")
  maxPatientsPerDay   Int?      @map("max_patients_per_day")
  consultationFee     Decimal?  @map("consultation_fee") @db.Decimal(10, 2)
  locationScope       String    @default("SINGLE") @map("location_scope")
  allowedLocations    String[]  @map("allowed_locations")
  crossLocationAccess Boolean   @default(false) @map("cross_location_access")
  status              String    @default("INVITED")
  invitedById         String?   @map("invited_by")
  invitationSentAt    DateTime? @map("invitation_sent_at")
  acceptedAt          DateTime? @map("accepted_at")
  joinedAt            DateTime? @map("joined_at")
  leftAt              DateTime? @map("left_at")
  removalReason       String?   @map("removal_reason")
  isActive            Boolean   @default(false) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  doctor   DoctorRegistry @relation(fields: [doctorId], references: [id])
  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  location TenantLocation? @relation(fields: [locationId], references: [id])

  @@map("doctor_org_affiliations")
}

model PlatformAuditLog {
  id          String   @id @default(uuid())
  eventType   String   @map("event_type")
  actorType   String   @map("actor_type")
  actorId     String?  @map("actor_id")
  actorEmail  String?  @map("actor_email")
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  targetName  String?  @map("target_name")
  description String?
  metadata    Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  hash        String
  createdAt   DateTime @default(now()) @map("created_at")

  actor PlatformUser? @relation(fields: [actorId], references: [id])

  @@map("platform_audit_logs")
}

// ─────────────────────────────────────────
// TENANT LEVEL (stored in same DB, tenant_id scoped)
// ─────────────────────────────────────────

model TenantUser {
  id                   String    @id @default(uuid())
  tenantId             String    @map("tenant_id")
  email                String
  passwordHash         String    @map("password_hash")
  mfaSecret            String?   @map("mfa_secret")
  mfaEnabled           Boolean   @default(false) @map("mfa_enabled")
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  phone                String?
  gender               String?
  photoUrl             String?   @map("photo_url")
  employeeId           String?   @map("employee_id")
  roleId               String    @map("role_id")
  primaryLocationId    String    @map("primary_location_id")
  locationScope        String    @default("SINGLE") @map("location_scope")
  allowedLocations     String[]  @map("allowed_locations")
  doctorRegistryId     String?   @map("doctor_registry_id")
  lastLogin            DateTime? @map("last_login")
  passwordChangedAt    DateTime? @map("password_changed_at")
  forcePasswordChange  Boolean   @default(true) @map("force_password_change")
  isActive             Boolean   @default(true) @map("is_active")
  deactivatedAt        DateTime? @map("deactivated_at")
  registrationSource   String    @default("ADMIN_INVITE") @map("registration_source")
  selfRegApprovedById  String?   @map("self_reg_approved_by")
  selfRegApprovedAt    DateTime? @map("self_reg_approved_at")
  createdById          String?   @map("created_by")
  deviceTokens         Json?     @default("[]") @map("device_tokens")
  apnsToken            String?   @map("apns_token")
  fcmToken             String?   @map("fcm_token")
  deviceType           String?   @map("device_type")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  role TenantRole @relation(fields: [roleId], references: [id])

  @@unique([tenantId, email])
  @@map("tenant_users")
}

model TenantRole {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  name         String
  description  String?
  systemRoleId String?  @map("system_role_id")
  isSystemRole Boolean  @default(false) @map("is_system_role")
  isActive     Boolean  @default(true) @map("is_active")
  createdById  String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  permissions  TenantRolePermission[]
  specialFlags TenantRoleSpecialFlag[]
  users        TenantUser[]

  @@unique([tenantId, name])
  @@map("tenant_roles")
}

model TenantRolePermission {
  id       String @id @default(uuid())
  roleId   String @map("role_id")
  moduleId String @map("module_id")
  resource String
  action   String

  role TenantRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId, resource, action])
  @@map("tenant_role_permissions")
}

model TenantRoleSpecialFlag {
  id        String  @id @default(uuid())
  roleId    String  @map("role_id")
  flag      String
  isEnabled Boolean @default(true) @map("is_enabled")

  role TenantRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, flag])
  @@map("tenant_role_special_flags")
}

model Department {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  locationId   String?  @map("location_id")
  name         String
  code         String
  type         String?
  headUserId   String?  @map("head_user_id")
  phoneExt     String?  @map("phone_extension")
  colorCode    String?  @map("color_code")
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([tenantId, locationId, code])
  @@map("departments")
}

model Patient {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  patientId        String    @unique @map("patient_id")
  locationId       String    @map("location_id")
  registrationType String    @default("WALKIN") @map("registration_type")
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  dateOfBirth      DateTime? @map("date_of_birth")
  ageYears         Int?      @map("age_years")
  gender           String
  bloodGroup       String?   @map("blood_group")
  nationalId       String?   @map("national_id")
  photoUrl         String?   @map("photo_url")
  mobile           String
  alternatePhone   String?   @map("alternate_phone")
  email            String?
  address          Json?
  emergencyContact Json?     @map("emergency_contact")
  allergies        String[]
  allergyDetails   Json?     @map("allergy_details")
  existingConditions String[] @map("existing_conditions")
  currentMedications Json?   @map("current_medications")
  pastSurgeries    String?   @map("past_surgeries")
  familyHistory    String?   @map("family_history")
  insurance        Json?
  registeredById   String?   @map("registered_by")
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  queueTokens         QueueToken[]
  appointments        Appointment[]
  consultations       Consultation[]
  prescriptions       Prescription[]
  labOrders           LabOrder[]
  triageRecords       TriageRecord[]
  vitals              Vital[]
  admissions          Admission[]
  invoices            Invoice[]
  accessLogs          PatientAccessLog[]
  emergencyVisits     EmergencyVisit[]
  medicalCertificates MedicalCertificate[]

  @@map("patients")
}

model QueueToken {
  id                    String    @id @default(uuid())
  tenantId              String    @map("tenant_id")
  tokenNumber           Int       @map("token_number")
  locationId            String    @map("location_id")
  queueDate             DateTime  @map("queue_date") @db.Date
  patientId             String    @map("patient_id")
  appointmentId         String?   @map("appointment_id")
  doctorId              String?   @map("doctor_id")
  departmentId          String?   @map("department_id")
  visitType             String    @default("NEW") @map("visit_type")
  priority              String    @default("NORMAL")
  status                String    @default("WAITING")
  checkInTime           DateTime  @default(now()) @map("check_in_time")
  calledTime            DateTime? @map("called_time")
  consultStart          DateTime? @map("consult_start")
  completedAt           DateTime? @map("completed_at")
  estimatedWaitMinutes  Int?      @map("estimated_wait_minutes")
  notes                 String?
  createdById           String?   @map("created_by")
  createdAt             DateTime  @default(now()) @map("created_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("queue_tokens")
}

model Appointment {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  locationId         String    @map("location_id")
  patientId          String    @map("patient_id")
  doctorId           String    @map("doctor_id")
  departmentId       String?   @map("department_id")
  appointmentDate    DateTime  @map("appointment_date") @db.Date
  appointmentTime    String    @map("appointment_time")
  durationMinutes    Int       @default(15) @map("duration_minutes")
  type               String    @default("NEW")
  source             String    @default("RECEPTION")
  chiefComplaint     String?   @map("chief_complaint")
  notes              String?
  status             String    @default("SCHEDULED")
  cancelledById      String?   @map("cancelled_by")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason")
  rescheduledFromId  String?   @map("rescheduled_from")
  reminder24hSent    Boolean   @default(false) @map("reminder_sent_24h")
  reminder1hSent     Boolean   @default(false) @map("reminder_sent_1h")
  createdById        String?   @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("appointments")
}

model Consultation {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  locationId         String    @map("location_id")
  patientId          String    @map("patient_id")
  doctorId           String    @map("doctor_id")
  queueTokenId       String?   @map("queue_token_id")
  appointmentId      String?   @map("appointment_id")
  chiefComplaint     String    @map("chief_complaint")
  historySubjective  String?   @map("history_subjective")
  historyObjective   String?   @map("history_objective")
  assessment         String?
  plan               String?
  examinationFindings Json?    @map("examination_findings")
  vitalsSnapshot     Json?     @map("vitals_snapshot")
  status             String    @default("DRAFT")
  startedAt          DateTime  @default(now()) @map("started_at")
  completedAt        DateTime? @map("completed_at")
  isCrossLocation    Boolean   @default(false) @map("is_cross_location")
  originalLocationId String?   @map("original_location_id")
  accessReason       String?   @map("access_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  patient   Patient                  @relation(fields: [patientId], references: [id])
  diagnoses ConsultationDiagnosis[]
  prescriptions Prescription[]

  @@map("consultations")
}

model ConsultationDiagnosis {
  id             String @id @default(uuid())
  consultationId String @map("consultation_id")
  icdCode        String? @map("icd_code")
  description    String
  type           String @default("PRIMARY")
  sortOrder      Int    @default(0) @map("sort_order")

  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("consultation_diagnoses")
}

model Prescription {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  rxNumber          String    @unique @map("rx_number")
  locationId        String    @map("location_id")
  consultationId    String?   @map("consultation_id")
  patientId         String    @map("patient_id")
  doctorId          String    @map("doctor_id")
  status            String    @default("PENDING")
  validityDate      DateTime  @map("validity_date") @db.Date
  notes             String?
  issuedAt          DateTime  @default(now()) @map("issued_at")
  sentToPharmacyAt  DateTime? @map("sent_to_pharmacy_at")
  cancelledAt       DateTime? @map("cancelled_at")
  cancelledById     String?   @map("cancelled_by")
  cancellationReason String?  @map("cancellation_reason")
  createdAt         DateTime  @default(now()) @map("created_at")

  patient      Patient              @relation(fields: [patientId], references: [id])
  consultation Consultation?        @relation(fields: [consultationId], references: [id])
  items        PrescriptionItem[]

  @@map("prescriptions")
}

model PrescriptionItem {
  id             String  @id @default(uuid())
  prescriptionId String  @map("prescription_id")
  drugId         String? @map("drug_id")
  drugName       String  @map("drug_name")
  genericName    String? @map("generic_name")
  dosageForm     String? @map("dosage_form")
  strength       String?
  dosage         String?
  frequency      String?
  durationDays   Int?    @map("duration_days")
  route          String?
  instructions   String?
  quantity       Decimal? @db.Decimal(10, 2)
  refillsAllowed Int     @default(0) @map("refills_allowed")
  isControlled   Boolean @default(false) @map("is_controlled")
  status         String  @default("PENDING")
  sortOrder      Int     @default(0) @map("sort_order")

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@map("prescription_items")
}

model LabOrder {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  orderNumber   String    @unique @map("order_number")
  locationId    String    @map("location_id")
  consultationId String?  @map("consultation_id")
  patientId     String    @map("patient_id")
  doctorId      String    @map("doctor_id")
  priority      String    @default("ROUTINE")
  fastingRequired Boolean @default(false) @map("fasting_required")
  clinicalNotes String?   @map("clinical_notes")
  status        String    @default("ORDERED")
  orderedAt     DateTime  @default(now()) @map("ordered_at")

  patient Patient        @relation(fields: [patientId], references: [id])
  items   LabOrderItem[]
  results LabResult[]

  @@map("lab_orders")
}

model LabOrderItem {
  id         String @id @default(uuid())
  labOrderId String @map("lab_order_id")
  testCode   String? @map("test_code")
  testName   String @map("test_name")
  category   String?
  urgency    String @default("ROUTINE")
  status     String @default("PENDING")

  labOrder LabOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)

  @@map("lab_order_items")
}

model LabResult {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  labOrderId      String    @map("lab_order_id")
  locationId      String    @map("location_id")
  validatedById   String?   @map("validated_by")
  validatedAt     DateTime? @map("validated_at")
  isCritical      Boolean   @default(false) @map("is_critical")
  criticalNotifiedAt DateTime? @map("critical_notified_at")
  criticalAckById String?   @map("critical_ack_by")
  notes           String?
  status          String    @default("PENDING_VALIDATION")
  amendedFromId   String?   @map("amended_from")
  amendmentReason String?   @map("amendment_reason")
  createdAt       DateTime  @default(now()) @map("created_at")

  labOrder LabOrder          @relation(fields: [labOrderId], references: [id])
  items    LabResultItem[]

  @@map("lab_results")
}

model LabResultItem {
  id           String   @id @default(uuid())
  labResultId  String   @map("lab_result_id")
  testName     String   @map("test_name")
  resultValue  String?  @map("result_value")
  resultUnit   String?  @map("result_unit")
  refRangeLow  Decimal? @map("ref_range_low") @db.Decimal(10, 3)
  refRangeHigh Decimal? @map("ref_range_high") @db.Decimal(10, 3)
  refRangeText String?  @map("ref_range_text")
  flag         String?
  method       String?
  analyzer     String?
  sortOrder    Int      @default(0) @map("sort_order")

  labResult LabResult @relation(fields: [labResultId], references: [id], onDelete: Cascade)

  @@map("lab_result_items")
}

model TriageRecord {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  locationId       String   @map("location_id")
  patientId        String   @map("patient_id")
