  maxStockLevel   Int      @default(100) @map("max_stock_level")
  unitCost        Decimal? @map("unit_cost") @db.Decimal(10, 2)
  supplier        String?
  storageLocation String?  @map("storage_location")
  isConsumable    Boolean  @default(true) @map("is_consumable")
  isActive        Boolean  @default(true) @map("is_active")
  lastRestockedAt DateTime? @map("last_restocked_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  transactions InventoryTransaction[]

  @@unique([tenantId, locationId, itemCode])
  @@map("inventory_items")
}

model InventoryTransaction {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  itemId          String   @map("item_id")
  transactionType String   @map("transaction_type")
  quantity        Int
  referenceType   String?  @map("reference_type")
  referenceId     String?  @map("reference_id")
  departmentId    String?  @map("department_id")
  remarks         String?
  performedById   String   @map("performed_by")
  createdAt       DateTime @default(now()) @map("created_at")

  item InventoryItem @relation(fields: [itemId], references: [id])

  @@index([tenantId, itemId])
  @@map("inventory_transactions")
}

// ─────────────────────────────────────────
// ASSET MANAGEMENT
// ─────────────────────────────────────────

model Asset {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  locationId        String    @map("location_id")
  assetCode         String    @map("asset_code")
  name              String
  category          String
  brand             String?
  model             String?
  serialNumber      String?   @map("serial_number")
  purchaseDate      DateTime? @map("purchase_date") @db.Date
  purchaseCost      Decimal?  @map("purchase_cost") @db.Decimal(12, 2)
  warrantyExpiry    DateTime? @map("warranty_expiry") @db.Date
  departmentId      String?   @map("department_id")
  assignedToId      String?   @map("assigned_to")
  assignedToName    String?   @map("assigned_to_name")
  condition         String    @default("GOOD")
  lastMaintenanceDate DateTime? @map("last_maintenance_date")
  nextMaintenanceDate DateTime? @map("next_maintenance_date")
  status            String    @default("ACTIVE")
  disposalDate      DateTime? @map("disposal_date")
  disposalReason    String?   @map("disposal_reason")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  maintenanceLogs AssetMaintenance[]

  @@unique([tenantId, assetCode])
  @@map("assets")
}

model AssetMaintenance {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  assetId         String    @map("asset_id")
  maintenanceType String    @map("maintenance_type")
  description     String
  performedById   String?   @map("performed_by")
  performedByName String?   @map("performed_by_name")
  vendor          String?
  cost            Decimal?  @db.Decimal(10, 2)
  scheduledDate   DateTime? @map("scheduled_date") @db.Date
  completedDate   DateTime? @map("completed_date") @db.Date
  nextDueDate     DateTime? @map("next_due_date") @db.Date
  status          String    @default("SCHEDULED")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("asset_maintenance")
}

// ─────────────────────────────────────────
// GRIEVANCE / FEEDBACK
// ─────────────────────────────────────────

model Grievance {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  ticketNumber     String    @unique @map("ticket_number")
  locationId       String    @map("location_id")
  complainantType  String    @map("complainant_type")
  complainantName  String    @map("complainant_name")
  complainantPhone String?   @map("complainant_phone")
  complainantEmail String?   @map("complainant_email")
  patientId        String?   @map("patient_id")
  category         String
  severity         String    @default("MEDIUM")
  subject          String
  description      String
  departmentId     String?   @map("department_id")
  assignedToId     String?   @map("assigned_to")
  assignedToName   String?   @map("assigned_to_name")
  resolution       String?
  resolvedAt       DateTime? @map("resolved_at")
  resolvedById     String?   @map("resolved_by")
  satisfactionScore Int?     @map("satisfaction_score")
  escalatedTo      String?   @map("escalated_to")
  escalatedAt      DateTime? @map("escalated_at")
  status           String    @default("OPEN")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@map("grievances")
}

