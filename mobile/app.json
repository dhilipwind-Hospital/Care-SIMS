{
  "expo": {
    "name": "Ayphen HMS",
    "slug": "ayphen-hms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F766E"
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ayphencare.hms",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Ayphen HMS needs camera access to scan patient IDs, prescription barcodes, and take clinical photos.",
        "NSPhotoLibraryUsageDescription": "Ayphen HMS needs photo library access to upload patient documents.",
        "NSFaceIDUsageDescription": "Ayphen HMS uses Face ID for secure authentication.",
        "NSMicrophoneUsageDescription": "Ayphen HMS needs microphone access for voice notes during consultations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F766E"
      },
      "package": "com.ayphencare.hms",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-camera",
      "expo-barcode-scanner",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0F766E",
          "imageWidth": 200
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0F766E"
        }
      ]
    ]
  }
}
